# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
# Dev (SQLite, no setup required):
DATABASE_URL=sqlite+aiosqlite:///./skladbase.db
# Prod (Postgres):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/skladbase

# --- Telegram ---
BOT_TOKEN=
# tg_id адміністратора — отримувач повідомлень техпідтримки (/support)
ADMIN_TG_ID=
# HTTPS-адреса Mini App (Cloudflare Workers) — кнопка "Відкрити" у /start
MINI_APP_URL=

# --- WayForPay ---
WFP_MERCHANT=
WFP_SECRET=
WFP_DOMAIN=

# --- NOWPayments ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
