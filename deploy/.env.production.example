# Прод-конфіг SkladBase. Скопіювати на сервер як /opt/skladbase/.env
# (читають ОБИДВА systemd-юніти: skladbase-web.service і
# skladbase-scheduler.service). Заповнити реальними значеннями, ніколи не
# комітити з даними.

# --- Database (Postgres у проді) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/skladbase

# --- Telegram ---
BOT_TOKEN=
INIT_DATA_MAX_AGE_HOURS=24

# --- Секрети at rest (AES-256-GCM, app/security/crypto.py) ---
# base64, рівно 32 байти: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# --- Планувальник ---
# web-процес НЕ піднімає крони — лише skladbase-scheduler.service
# (app/worker.py, ROADМАП Стадія 9a).
RUN_SCHEDULER=False

# --- Довірені проксі (nginx на тому самому хості — за замовчуванням loopback) ---
TRUSTED_PROXY_IPS=127.0.0.1,::1

# --- WayForPay ---
WFP_MERCHANT=
WFP_SECRET=
WFP_DOMAIN=

# --- NOWPayments ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Курс для крипто-чекауту (свідоме спрощення MVP, не live-курс) ---
UAH_USD_RATE=41.5

# --- Cloudflare R2 (фото) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
MAX_PHOTO_UPLOAD_MB=5
